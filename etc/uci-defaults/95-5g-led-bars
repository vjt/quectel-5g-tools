#!/bin/sh
# GL.iNet GL-X3000-specific LED retargeting, applied once on first boot.
#
# Two changes against the mediatek/filogic board.d/01_leds defaults:
#
# 1. green:5g:led{1..4} (the four signal-bar LEDs on the panel) come
#    out of the box wired to a netdev trigger on wwan0 with mode
#    "link tx rx" — that's binary on/off, not signal-driven, so the
#    bars peg at 4/4 the moment the MBIM session is up regardless of
#    actual RSRP. Disable the trigger so the 5g-led-bars daemon can
#    drive their brightness directly. Without this, `service system
#    reload` would briefly flip trigger=netdev back into the kernel
#    and clobber the daemon's brightness writes.
#
# 2. green:wan (labelled "INTERNET" on the panel) is bound to eth0 by
#    default — appropriate for a stock GL-X3000 deployment where the
#    upstream is wired Ethernet, but on jeeves the actual upstream is
#    the modem on wwan0. Rebind so the LED reflects modem state /
#    traffic instead.
#
# Sections themselves are retained (just retriggered / redirected) so
# users disabling 5g-led-bars or pivoting back to a wired upstream can
# revert with a couple of `uci set` calls instead of recreating the
# section from scratch.

. /lib/functions.sh

board=$(board_name)
case "$board" in
    glinet,gl-x3000|glinet,gl-xe3000) ;;
    *) exit 0 ;;
esac

[ -f /etc/config/system ] || exit 0

changed=0

for n in 1 2 3 4; do
    section="led_5g_$n"
    [ -n "$(uci -q get system.$section)" ] || continue
    [ "$(uci -q get system.$section.trigger)" = "none" ] && continue

    uci -q set system.$section.trigger='none'
    uci -q delete system.$section.mode
    uci -q delete system.$section.dev
    changed=1
done

if [ -n "$(uci -q get system.led_wan)" ]; then
    if [ "$(uci -q get system.led_wan.dev)" != "wwan0" ] \
       || [ "$(uci -q get system.led_wan.trigger)" != "netdev" ] \
       || [ "$(uci -q get system.led_wan.mode)" != "link tx rx" ]; then
        uci -q set system.led_wan.trigger='netdev'
        uci -q set system.led_wan.dev='wwan0'
        uci -q set system.led_wan.mode='link tx rx'
        changed=1
    fi
fi

[ "$changed" = 1 ] && uci commit system

exit 0
