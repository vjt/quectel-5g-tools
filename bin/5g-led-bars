#!/usr/bin/env lua
-- 5g-led-bars: drive GL-X3000 5G signal LEDs from modem RSRP.
--
-- Polls the modem at a configurable interval, maps PCC RSRP to a 0..4
-- bar count, and writes the corresponding brightness to the four
-- `green:5g:led{1..4}` GPIO LEDs. On startup the LED triggers are set
-- to `none` so the netdev trigger does not fight back.

package.path = "/usr/lib/lua/?.lua;/usr/lib/lua/?/init.lua;" .. package.path

local quectel = require("quectel")
local utils = require("quectel.utils")

local LED_PREFIX = "/sys/class/leds/green:5g:led"
local LED_COUNT = 4

-- RSRP (dBm) thresholds for bars 1..4. Bar N is lit when rsrp >= THRESHOLDS[N].
local THRESHOLDS = { -115, -105, -95, -85 }

-- procd init script sets stdout/stderr=1, so anything we write here gets
-- picked up by ulog → syslog. Tag every line so logread filters cleanly.
local function log(fmt, ...)
    io.stderr:write(string.format("5g-led-bars: " .. fmt .. "\n", ...))
    io.stderr:flush()
end

local function write_file(path, value)
    local f = io.open(path, "w")
    if not f then return end
    f:write(value)
    f:close()
end

local function set_trigger_none()
    for n = 1, LED_COUNT do
        write_file(LED_PREFIX .. n .. "/trigger", "none\n")
    end
end

local function rsrp_to_bars(rsrp)
    if not rsrp then return 0 end
    local bars = 0
    for _, t in ipairs(THRESHOLDS) do
        if rsrp >= t then bars = bars + 1 end
    end
    return bars
end

local function apply_bars(bars)
    for n = 1, LED_COUNT do
        write_file(LED_PREFIX .. n .. "/brightness", bars >= n and "1" or "0")
    end
end

-- Prefer 5G NR RSRP whenever an NR carrier is present, even in NSA where
-- the PCC is the LTE anchor: the LEDs are labelled "5G" and the user
-- cares about NR coverage, not the LTE leg holding control plane. Pick
-- the strongest NR carrier (PCC or any NR SCC); fall back to PCC RSRP
-- if there are no NR carriers (pure-LTE attach).
local function best_nr_rsrp(ca)
    if not ca then return nil, nil end
    local best, best_src = nil, nil
    local function consider(c, src)
        if c and c.rat == "5g" and c.rsrp then
            if not best or c.rsrp > best then best, best_src = c.rsrp, src end
        end
    end
    consider(ca.pcc, "PCC")
    for i, scc in ipairs(ca.scc or {}) do
        consider(scc, "SCC[" .. i .. "]")
    end
    return best, best_src
end

-- Compact summary of the parsed status, used only on the failure path to
-- give the operator a fighting chance of figuring out which piece of the
-- modem reply went missing without re-running by hand. Cheap (just field
-- reads) and bounded (no neighbours, no full dump).
local function describe_carrier(c)
    if not c then return "nil" end
    return string.format("rat=%s,rsrp=%s,band=%s,arfcn=%s",
        tostring(c.rat), tostring(c.rsrp),
        tostring(c.band), tostring(c.arfcn))
end

local function summarize_status(status)
    if not status then return "status=nil" end
    local serving = status.serving or {}
    local ca = status.ca or {}
    return string.format(
        "serving={state=%s,rat=%s,rsrp=%s} pcc={%s} scc=%d",
        tostring(serving.state), tostring(serving.rat),
        tostring(serving.rsrp), describe_carrier(ca.pcc),
        ca.scc and #ca.scc or 0)
end

local function read_rsrp()
    local m = quectel.create_modem()
    local ok, status = pcall(function() return m:get_signal_status() end)
    pcall(function() m:close() end)
    if not ok or not status then
        local err = (not ok and tostring(status)) or "no status"
        return nil, nil, err
    end

    local nr, src = best_nr_rsrp(status.ca)
    if nr then return nr, "NR " .. src end

    if status.ca and status.ca.pcc and status.ca.pcc.rsrp then
        return status.ca.pcc.rsrp, "LTE PCC"
    end
    if status.serving and status.serving.rsrp then
        return status.serving.rsrp, "serving"
    end
    return nil, nil, "no rsrp in modem reply (" .. summarize_status(status) .. ")"
end

local interval = quectel.uci.get_number("quectel", "led_bars", "interval", 10)
local device_for_log = quectel.uci.get_string("quectel", "modem", "device",
                                              "/dev/ttyUSB2")

log("starting: device=%s interval=%ds thresholds=[%s] dBm",
    device_for_log, interval, table.concat(THRESHOLDS, ","))

set_trigger_none()
apply_bars(0)

local last_bars = 0
local consecutive_failures = 0

-- Re-asserting trigger=none on every cycle is cheap (4 sysfs writes) and
-- guards against `/etc/init.d/system reload` (or any external re-apply
-- of UCI led config) flipping the trigger back to netdev. Without it,
-- a quectel UCI reload would silently break the bars until next reboot.
--
-- On read failure (AT serial lock contention with another quectel-5g-tools
-- consumer, modem busy under load, transient cdc_mbim hiccup) we hold the
-- last successful bar count rather than dropping to 0. Single missed poll
-- shouldn't make the LEDs flicker off and back on — that's misleading
-- when nothing's actually wrong with the link.
while true do
    set_trigger_none()
    local rsrp, src, err = read_rsrp()
    if rsrp then
        local bars = rsrp_to_bars(rsrp)
        apply_bars(bars)
        if bars ~= last_bars or consecutive_failures > 0 then
            log("rsrp=%d dBm (%s) -> %d bars%s",
                rsrp, src, bars,
                consecutive_failures > 0 and
                    string.format(" (recovered after %d failed reads)",
                                  consecutive_failures) or "")
        end
        last_bars = bars
        consecutive_failures = 0
    else
        consecutive_failures = consecutive_failures + 1
        -- Log every miss for the first few, then back off to avoid spam if
        -- the modem stays unreachable. 1, 2, 5, 10, 30, 60, 120, …
        if consecutive_failures == 1
           or consecutive_failures == 2
           or consecutive_failures == 5
           or consecutive_failures % 30 == 0 then
            log("rsrp read failed (%s); holding %d bars (miss #%d)",
                err or "unknown", last_bars, consecutive_failures)
        end
    end
    utils.sleep(interval)
end
