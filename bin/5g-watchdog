#!/usr/bin/env lua
-- 5g-watchdog: detect NSA 5G NR SCG drops on the RM520N and force a
-- re-attach via ModemManager + netifd.
--
-- Failure mode targeted: the modem stays attached to the LTE master
-- but the cell does not (re)add the NR secondary carrier, so the
-- bearer keeps working at LTE-only throughput. Recovery requires the
-- UE to re-advertise NSA capability on a fresh attach.
--
-- Recovery is two stages per cycle:
--   * stage 1 — mode_toggle: mmcli --set-allowed-modes='4g' then
--     restore. Forces firmware to drop+restart NR measurements at the
--     RAT layer. Cheap, modem stays connected.
--   * stage 2 — bearer_reconnect: `ifdown <iface>; sleep 5; ifup <iface>`.
--     Brings the netifd / MM bearer down and back up, forcing a fresh
--     PDN attach. Heavier (LTE blip too) but covers the case where
--     mode_toggle leaves the bearer's "no SCG" cache stuck. Confirmed
--     2026-05-04 incident: 3× mode_toggle + 1× COPS toggle all failed,
--     `ifdown wwan; ifup wwan` recovered NR in seconds on the same n78
--     cell that had been "missing" the whole time.
-- A cycle succeeds if EITHER stage gets NR back. Only if BOTH fail does
-- the cycle count as a failure for the backoff counter.
--
-- Detection vs recovery split:
--
--   * Detection ("is NR actually attached right now?") goes over AT
--     via the shared `quectel.modem` lib. AT+QCAINFO gives the modem's
--     own carrier-aggregation list (pcc + scc[] each tagged
--     rat="lte"|"5g"); AT+QNWPREFCFG gives the mode preference. mmcli
--     is kept out of detection because its `access-technologies` field
--     comes from the QMI registration surface, which keeps reporting
--     `5gnr` after the NSA SCG has been dropped — i.e. it lies in
--     exactly the failure mode we're trying to detect.
--   * Recovery (mode toggle) goes through mmcli. Mode changes drop the
--     bearer, and that's MM's job — driving bearer disconnect/reconnect
--     from outside MM would leave its state machine guessing. The
--     `current-modes` field we read as a pre-action snapshot is config
--     state, not the lying registration view, so trusting mmcli for it
--     is fine.
--
-- Backoff model (replaces the old 24h-window daily_cap):
--   * After a successful recovery: cooldown_ok (default 300s) — give
--     the cell a chance to settle before we test it again.
--   * After a failed CYCLE (both stages exhausted): cooldown_fail
--     (default 300s, doubles each consecutive failure up to
--     cooldown_fail_max=1800s/30min) — back off so we don't flap a
--     wedged radio, but stay aggressive (worst-case wait between
--     cycles is 30min, not 4h). Resets on next success or cell-driven
--     recovery.
--
-- Telegram alerts (opt-in, off by default — set telegram_token and
-- telegram_chat in UCI to enable):
--   * 🔻 after `alert_after_failed` consecutive failed actions
--   * 🔻 if NR has been detached for `alert_detach_seconds` and the
--     daemon hasn't been able to act (e.g. wedged in cooldown)
--   * ✅ on recovery, but only if an alert was sent during the current
--     incident — no spam for incidents we never escalated on.

package.path = "/usr/lib/lua/?.lua;/usr/lib/lua/?/init.lua;" .. package.path

local quectel_uci = require("quectel.uci")
local utils = require("quectel.utils")
local Modem = require("quectel.modem")
local jsonc = require("luci.jsonc")

local AT_DEVICE = quectel_uci.get_string("quectel", "modem", "device", "/dev/ttyUSB2")
local AT_TIMEOUT = 5         -- seconds, AT response timeout
-- The 5g-* helpers and the watchdog all share /dev/ttyUSB2 via
-- /var/lock/quectel-modem.lock. The default 2000ms wait works fine in
-- steady state, but at boot or right after a sysupgrade the helpers
-- are simultaneously starting up and lock contention is heaviest.
-- Five seconds is enough headroom for 5g-led-bars (refresh_interval=5s)
-- to finish its current poll and release the lock.
local AT_LOCK_WAIT_MS = 5000

local STATE_PATH = "/var/run/5g-watchdog.state"
local RECOVERY_POLL_INTERVAL = 3   -- seconds between mmcli polls while waiting for NR
-- RECOVERY_MAX_WAIT is read from UCI (recovery_wait_seconds, default
-- 180s). 60s was too tight: empirically the cell sometimes brings NR
-- back 90–150s after the mode toggle and we'd misclassify a slow
-- success as a failure → trigger the long fail cooldown for nothing.
local RECOVERY_MAX_WAIT

-- Log via `logger -t 5g-watchdog` so messages land in syslog (logread)
-- regardless of whether we're under procd or running standalone. We
-- deliberately don't also write to stderr: procd's ulog wiring would
-- duplicate every line in logread when the service is running normally,
-- which is the common case. The fork-per-log-line cost is fine — we
-- log on transitions only, so cadence is sub-1/min in steady state.
local function log(fmt, ...)
    local msg = string.format(fmt, ...)
    local p = io.popen("logger -t 5g-watchdog", "w")
    if p then
        p:write(msg)
        p:close()
    end
end

-- Wire SIGTERM/SIGINT/SIGHUP to a clean exit so procd-driven stops show
-- up in syslog as a deliberate shutdown rather than a silent vanish.
-- luaposix is a hard dep of this package so the pcall fallback is just
-- belt-and-braces for stripped-down test envs.
local posix_signal_ok, posix_signal = pcall(require, "posix.signal")
if posix_signal_ok then
    local function shutdown(signum)
        log("received signal %d, shutting down", signum)
        os.exit(0)
    end
    posix_signal.signal(posix_signal.SIGTERM, shutdown)
    posix_signal.signal(posix_signal.SIGINT, shutdown)
    posix_signal.signal(posix_signal.SIGHUP, shutdown)
end

-- ---------------------------------------------------------------------
-- mmcli helpers
-- ---------------------------------------------------------------------

-- Run a command, return (stdout, exit_status). Uses io.popen so we
-- never block on a mmcli that wedges itself; the parent procd respawn
-- catches the case where we stall longer than RECOVERY_MAX_WAIT.
local function run(cmd)
    local p = io.popen(cmd .. " 2>&1", "r")
    if not p then return nil, -1 end
    local out = p:read("*a") or ""
    local ok, _, code = p:close()
    return out, ok and 0 or (code or 1)
end

-- Run a command, parse stdout as JSON. Returns (table, 0) on success,
-- (nil, code) otherwise. Used for `mmcli -J ...` calls.
local function run_json(cmd)
    local out, code = run(cmd)
    if code ~= 0 or not out or out == "" then return nil, code end
    local parsed = jsonc.parse(out)
    if type(parsed) ~= "table" then return nil, -1 end
    return parsed, 0
end

local function discover_modem_index()
    local data = run_json("mmcli -J -L")
    local list = data and data["modem-list"]
    if type(list) ~= "table" or not list[1] then return nil end
    local idx = list[1]:match("/Modem/(%d+)$")
    return idx and tonumber(idx) or nil
end

-- ---------------------------------------------------------------------
-- state file (atomic write + read-on-startup)
-- ---------------------------------------------------------------------
--
-- STATE_PATH lives under /var/run, which is tmpfs on OpenWrt: the file
-- survives a procd respawn (so we don't lose cooldown / failed-action
-- counters across daemon restart and end up double-acting on the modem)
-- but dies on reboot (correct — modem also comes up fresh after reboot).
-- Stale-state risk is bounded by STATE_TTL: anything older than 24h is
-- discarded so a wedged file from yesterday can't pin
-- consecutive_failed_actions forever.

local STATE_TTL = 86400

local function write_state(state)
    local tmp = STATE_PATH .. ".tmp"
    local f = io.open(tmp, "w")
    if not f then return end
    -- Sorted keys for diff-friendly output; volume is small.
    local keys = {}
    for k in pairs(state) do table.insert(keys, k) end
    table.sort(keys)
    for _, k in ipairs(keys) do
        f:write(string.format("%s=%s\n", k, tostring(state[k])))
    end
    f:close()
    os.rename(tmp, STATE_PATH)
end

-- Parse the flat key=value file back into a table. Values come back as
-- strings; callers cast to number/bool as needed. Returns nil if the
-- file isn't there or can't be opened.
local function read_state()
    local f = io.open(STATE_PATH, "r")
    if not f then return nil end
    local s = {}
    for line in f:lines() do
        local k, v = line:match("^([^=]+)=(.*)$")
        if k then s[k] = v end
    end
    f:close()
    return s
end

-- ---------------------------------------------------------------------
-- recovery actions
-- ---------------------------------------------------------------------

-- mmcli serialises `current-modes` as a single human-readable string
-- of the form "allowed: 3g, 4g, 5g; preferred: 5g" — this is config
-- state (what the user has the radio set to), NOT the lying
-- access-technologies registration view, so it's safe to read from
-- mmcli for the pre-action snapshot. -J doesn't break this out into
-- structured fields, so we string-parse it. Returns
-- (allowed_list, preferred_string).
local function parse_current_modes(s)
    if not s or s == "" or s == "--" then return {}, "" end
    local allowed_part, preferred = s:match("^%s*allowed:%s*(.-)%s*;%s*preferred:%s*(.-)%s*$")
    if not allowed_part then
        allowed_part = s:match("^%s*allowed:%s*(.-)%s*$") or s
        preferred = ""
    end
    local list = {}
    for m in allowed_part:gmatch("[^,%s]+") do table.insert(list, m) end
    return list, preferred or ""
end

-- Snapshot current allowed-modes + preferred-mode via mmcli, drop
-- allowed to 4g-only, wait, then restore exactly. The "drop+restore"
-- forces the firmware to re-evaluate RAT priorities and reattach NR
-- clean.
--
-- Stays on mmcli (rather than going AT) because mode changes drop the
-- bearer, and that's exactly MM's job to manage — going around MM with
-- AT+QNWPREFCFG would leave its bearer state machine guessing whether
-- the unsolicited disconnect is recoverable.
local function mode_toggle(idx)
    local data = run_json(string.format("mmcli -m %d -J", idx))
    if not data or type(data.modem) ~= "table" then
        log("mode_toggle: mmcli snapshot failed; refusing to run")
        return false
    end
    local g = data.modem.generic or {}
    local allowed, preferred = parse_current_modes(g["current-modes"])
    if #allowed == 0 then
        log("mode_toggle: no current allowed modes captured; refusing to run")
        return false
    end
    local allowed_pipes = table.concat(allowed, "|")
    local restore = string.format(
        "mmcli -m %d --set-allowed-modes='%s'%s",
        idx, allowed_pipes,
        (preferred ~= "" and preferred ~= "none")
            and (" --set-preferred-mode=" .. preferred) or "")
    log("mode_toggle: drop to 4g, then restore: %s", restore)

    local _, c1 = run(string.format("mmcli -m %d --set-allowed-modes='4g'", idx))
    utils.sleep(4)
    local _, c2 = run(restore)
    if c1 ~= 0 or c2 ~= 0 then
        log("mode_toggle: drop=%d restore=%d (non-zero) — restore cmd: %s",
            c1, c2, restore)
        return false
    end
    return true
end

-- Poll `ifstatus <iface>` (netifd JSON) until `up == want` and
-- `pending == false`. Returns true if the state is reached within
-- timeout, false otherwise. Used by bearer_reconnect to wait for the
-- iface to actually go down before bringing it back up, instead of a
-- blind sleep that may race with proto-handler teardown.
local function wait_iface_up(iface, want, timeout)
    local poll = 1
    local t0 = os.time()
    while os.time() - t0 < timeout do
        local data = run_json(string.format("ifstatus %s", iface))
        if data and data.up == want and data.pending == false then
            return true, os.time() - t0
        end
        utils.sleep(poll)
    end
    return false, timeout
end

-- bearer_reconnect: ifdown <iface>; wait for down; ifup <iface>. With
-- the wwan interface using proto=modemmanager, this drives MM through a
-- clean bearer disconnect + reconnect, which forces a fresh PDN attach
-- and (in the failure mode this watchdog targets) clears whatever stale
-- "no SCG" state mode_toggle can't reach. Returns true if both ifdown
-- and ifup succeed AND netifd confirms the down transition. The "did
-- NR come back?" check is left to the caller's measure_recovery.
local function bearer_reconnect(iface)
    log("bearer_reconnect: ifdown %s", iface)
    local _, c1 = run(string.format("ifdown %s", iface))
    if c1 ~= 0 then
        log("bearer_reconnect: ifdown returned %d for iface=%s", c1, iface)
        return false
    end
    local down_ok, down_secs = wait_iface_up(iface, false, 30)
    if not down_ok then
        log("bearer_reconnect: iface %s did not go down within 30s; aborting (no ifup)",
            iface)
        return false
    end
    log("bearer_reconnect: iface %s down after %ds; ifup %s",
        iface, down_secs, iface)
    local _, c2 = run(string.format("ifup %s", iface))
    if c2 ~= 0 then
        log("bearer_reconnect: ifup returned %d for iface=%s", c2, iface)
        return false
    end
    return true
end

-- ---------------------------------------------------------------------
-- detection (all-AT)
-- ---------------------------------------------------------------------

local function probe()
    -- One open/close per probe — both AT calls share the lock so we
    -- only contend with the rest of quectel-5g-tools once.
    local m = Modem.new(AT_DEVICE, AT_TIMEOUT, AT_LOCK_WAIT_MS)
    local ok, err = m:open()
    if not ok then return nil, "modem open: " .. tostring(err) end
    local sig, sig_err = m:get_signal_status()
    if not sig then
        m:close()
        return nil, "get_signal_status: " .. tostring(sig_err)
    end
    -- get_band_config("mode_pref") issues AT+QNWPREFCFG="mode_pref" and
    -- returns the raw value (e.g. "AUTO", "LTE", "NR5G", "LTE:NR5G").
    local mode_pref = m:get_band_config("mode_pref") or ""
    m:close()

    -- Carrier aggregation breakdown: pcc + scc[] each tagged with
    -- rat="lte"|"5g". This is the modem's own view, the only one that
    -- reflects whether NR is actually being aggregated on the bearer.
    local nr_carriers, lte_carriers = 0, 0
    local has_pcc = false
    if sig.ca then
        if sig.ca.pcc then
            has_pcc = true
            if sig.ca.pcc.rat == "5g" then nr_carriers = nr_carriers + 1
            else lte_carriers = lte_carriers + 1 end
        end
        for _, c in ipairs(sig.ca.scc or {}) do
            if c.rat == "5g" then nr_carriers = nr_carriers + 1
            else lte_carriers = lte_carriers + 1 end
        end
    end

    mode_pref = tostring(mode_pref):upper()
    -- nr_capable: the radio is configured to attempt NR. AUTO covers
    -- "use whatever's available"; otherwise the explicit list must
    -- include NR5G.
    local nr_capable = (mode_pref == "AUTO") or (mode_pref:find("NR5G") ~= nil)

    return {
        connected      = has_pcc,
        state          = has_pcc and "connected" or "no-carrier",
        nr_attached    = (nr_carriers > 0),
        nr_carriers    = nr_carriers,
        lte_carriers   = lte_carriers,
        nr_capable     = nr_capable,
        mode_pref      = mode_pref,
    }
end

-- ---------------------------------------------------------------------
-- main loop
-- ---------------------------------------------------------------------

local enabled = quectel_uci.get_bool("quectel", "watchdog", "enabled", true)
if not enabled then
    log("watchdog disabled in UCI; exiting")
    os.exit(0)
end

local poll_interval       = quectel_uci.get_number("quectel", "watchdog", "poll_interval", 60)
local degraded_samples    = quectel_uci.get_number("quectel", "watchdog", "degraded_samples", 5)
RECOVERY_MAX_WAIT         = quectel_uci.get_number("quectel", "watchdog", "recovery_wait_seconds", 180)
local cooldown_ok         = quectel_uci.get_number("quectel", "watchdog", "cooldown_ok", 300)
local cooldown_fail       = quectel_uci.get_number("quectel", "watchdog", "cooldown_fail", 300)
local cooldown_fail_max   = quectel_uci.get_number("quectel", "watchdog", "cooldown_fail_max", 1800)
local bearer_reconnect_enabled = quectel_uci.get_bool("quectel", "watchdog", "bearer_reconnect_enabled", true)
local bearer_iface        = quectel_uci.get_string("quectel", "watchdog", "bearer_iface", "wwan")
local alert_after_failed  = quectel_uci.get_number("quectel", "watchdog", "alert_after_failed", 0)
local alert_detach_secs   = quectel_uci.get_number("quectel", "watchdog", "alert_detach_seconds", 0)
local tg_token            = quectel_uci.get_string("quectel", "watchdog", "telegram_token", "")
local tg_chat             = quectel_uci.get_string("quectel", "watchdog", "telegram_chat", "")

-- Telegram is opt-in: empty token OR empty chat = disabled. The alert
-- thresholds also each independently no-op when set to 0.
local function tg_enabled()
    return tg_token ~= "" and tg_chat ~= ""
end

-- Hostname is shipped in the alert text so a single Telegram channel
-- can carry alerts from multiple routers without context confusion.
local function hostname()
    local f = io.open("/proc/sys/kernel/hostname", "r")
    if not f then return "unknown" end
    local h = (f:read("*l") or "unknown")
    f:close()
    return h
end
local HOSTNAME = hostname()

-- Telegram POST is backgrounded + capped at 10s so a hung api.telegram.org
-- call can't stall the watchdog loop. We still log the attempt so syslog
-- has a record even if the API never replies. parse_mode is intentionally
-- omitted: Markdown chokes on underscores (e.g. `mode_toggle` in the
-- recovery message) and would silently 400 the request.
local function notify_telegram(text)
    if not tg_enabled() then return end
    log("telegram alert: %s", text)
    local cmd = string.format(
        "(curl -sS --max-time 10 " ..
        "-d chat_id=%s " ..
        "--data-urlencode text=%q " ..
        "'https://api.telegram.org/bot%s/sendMessage' " ..
        ">/dev/null 2>&1) &",
        tg_chat, text, tg_token)
    os.execute(cmd)
end

log("starting up: probing modem over AT (%s)", AT_DEVICE)

-- Sanity check: can we reach the modem at all? If not, sleep + retry
-- once; if still bad, exit and let procd respawn us. This also catches
-- the case where the lock file is held by a wedged 5g-info / 5g-monitor
-- process across the whole startup window.
local first_p, first_err = probe()
if not first_p then
    log("modem unreachable over AT (%s); sleeping 30s and retrying",
        first_err or "?")
    utils.sleep(30)
    first_p, first_err = probe()
    if not first_p then
        log("modem still unreachable (%s); exiting (procd will respawn)",
            first_err or "?")
        os.exit(1)
    end
end
log("started: poll=%ds hysteresis=%d recovery_wait=%ds cooldown_ok=%ds cooldown_fail=%ds (max %ds) bearer_reconnect=%s (iface=%s) alert_after_failed=%d alert_detach=%ds telegram=%s",
    poll_interval, degraded_samples, RECOVERY_MAX_WAIT, cooldown_ok,
    cooldown_fail, cooldown_fail_max,
    bearer_reconnect_enabled and "on" or "off", bearer_iface,
    alert_after_failed, alert_detach_secs,
    tg_enabled() and "on" or "off")

local consecutive_degraded = 0
local cooldown_until = 0
local last_action_ts = 0
local last_recovery_seconds = 0
local actions_total_mode_toggle = 0
local actions_total_bearer_reconnect = 0
local consecutive_failed_actions = 0
-- nr_detached_since: unix-ts when the current detach started (0 = NR
-- attached or never observed detached). Reset to 0 on any recovery.
local nr_detached_since = 0
-- alerted_*: per-incident "did we already send this alert" flag, so a
-- long detach doesn't keep firing the same Telegram message every
-- minute. Both reset on recovery.
local alerted_failed = false
local alerted_detach_long = false

local function emit_state(p)
    local s = {
        nr_attached            = (p and p.nr_attached) and 1 or 0,
        nr_carriers            = p and p.nr_carriers or 0,
        lte_carriers           = p and p.lte_carriers or 0,
        nr_capable             = (p and p.nr_capable) and 1 or 0,
        connected              = (p and p.connected) and 1 or 0,
        modem_state            = p and p.state or "unknown",
        mode_pref              = p and p.mode_pref or "",
        consecutive_degraded   = consecutive_degraded,
        cooldown_until         = cooldown_until,
        last_action_ts         = last_action_ts,
        last_recovery_seconds  = last_recovery_seconds,
        actions_total_mode_toggle      = actions_total_mode_toggle,
        actions_total_bearer_reconnect = actions_total_bearer_reconnect,
        consecutive_failed_actions     = consecutive_failed_actions,
        nr_detached_since      = nr_detached_since,
        alerted_failed         = alerted_failed and 1 or 0,
        alerted_detach_long    = alerted_detach_long and 1 or 0,
        updated_ts             = os.time(),
    }
    write_state(s)
end

-- After an action, poll every RECOVERY_POLL_INTERVAL up to RECOVERY_MAX_WAIT
-- to record how long it took NR to come back. Returns seconds to recovery
-- (or RECOVERY_MAX_WAIT+1 if it never came back within the window).
local function measure_recovery()
    local t0 = os.time()
    while os.time() - t0 < RECOVERY_MAX_WAIT do
        utils.sleep(RECOVERY_POLL_INTERVAL)
        local p = probe()
        if p and p.nr_attached then
            return os.time() - t0, p
        end
    end
    return RECOVERY_MAX_WAIT + 1, probe()
end

-- Exponential backoff on consecutive failures: cooldown_fail,
-- 2*cooldown_fail, 4*cooldown_fail, ..., capped at cooldown_fail_max.
-- failures argument is the count *including* the failure we just took.
local function failure_cooldown(failures)
    local backoff = cooldown_fail * (2 ^ math.max(0, failures - 1))
    if backoff > cooldown_fail_max then backoff = cooldown_fail_max end
    return math.floor(backoff)
end

-- Reset the per-incident tracking after any recovery (action-driven or
-- cell-driven). If we'd previously alerted on this incident, send the
-- complementary "back up" notification so the alert isn't a dead end.
local function on_recovery(reason)
    local was_alerted = alerted_failed or alerted_detach_long
    if was_alerted then
        notify_telegram(string.format("✅ %s 5G NR back (%s)", HOSTNAME, reason))
    end
    consecutive_failed_actions = 0
    nr_detached_since = 0
    alerted_failed = false
    alerted_detach_long = false
end

-- One recovery cycle: try stage 1 (mode_toggle); if NR doesn't come
-- back, escalate to stage 2 (bearer_reconnect) if enabled. The cycle
-- counts as a success if either stage gets NR back, and as a failure
-- only when both are exhausted.
local function take_action()
    local now = os.time()
    if now < cooldown_until then return end

    -- The MM modem index can change at runtime (USB reset / udev
    -- re-enum / firmware reboot), so we rediscover just-in-time per
    -- action instead of caching.
    local mm_idx = discover_modem_index()
    if not mm_idx then
        log("no modem visible to ModemManager; skipping action")
        return
    end

    -- Stage 1: mode_toggle
    mode_toggle(mm_idx)
    actions_total_mode_toggle = actions_total_mode_toggle + 1
    local recovered_in, post = measure_recovery()
    last_action_ts = os.time()
    last_recovery_seconds = recovered_in

    if post and post.nr_attached then
        log("recovered NR via stage1 mode_toggle in %ds", recovered_in)
        cooldown_until = last_action_ts + cooldown_ok
        on_recovery(string.format("mode_toggle in %ds", recovered_in))
        consecutive_degraded = degraded_samples
        return
    end

    log("stage1 mode_toggle did NOT recover NR within %ds; %s",
        RECOVERY_MAX_WAIT,
        bearer_reconnect_enabled
            and "escalating to stage2 bearer_reconnect"
            or "stage2 bearer_reconnect disabled — counting cycle as failed")

    if bearer_reconnect_enabled then
        -- Stage 2: bearer_reconnect
        bearer_reconnect(bearer_iface)
        actions_total_bearer_reconnect = actions_total_bearer_reconnect + 1
        recovered_in, post = measure_recovery()
        last_action_ts = os.time()
        last_recovery_seconds = recovered_in

        if post and post.nr_attached then
            log("recovered NR via stage2 bearer_reconnect in %ds", recovered_in)
            cooldown_until = last_action_ts + cooldown_ok
            on_recovery(string.format("bearer_reconnect in %ds", recovered_in))
            consecutive_degraded = degraded_samples
            return
        end
        log("stage2 bearer_reconnect did NOT recover NR within %ds",
            RECOVERY_MAX_WAIT)
    end

    -- Both stages exhausted (or stage 2 disabled) — count the cycle as
    -- failed and back off.
    consecutive_failed_actions = consecutive_failed_actions + 1
    local backoff = failure_cooldown(consecutive_failed_actions)
    cooldown_until = last_action_ts + backoff
    log("recovery cycle FAILED (mode_toggle + bearer_reconnect) — consecutive failures=%d, next attempt in %ds",
        consecutive_failed_actions, backoff)
    if alert_after_failed > 0
            and not alerted_failed
            and consecutive_failed_actions >= alert_after_failed then
        notify_telegram(string.format(
            "🔻 %s 5G NR recovery failed %dx in a row — next try in %dm",
            HOSTNAME, consecutive_failed_actions, math.floor(backoff / 60)))
        alerted_failed = true
    end
    -- Clamp so the next-pass log doesn't say "sample 418/5".
    consecutive_degraded = degraded_samples
end

-- Transition-aware logging: keep the previous probe so we log only when
-- something actually changed (modem state flipped, NR came/went, user
-- pinned LTE, etc.) instead of spamming a line per 60s tick.
local last_probe = nil
local last_probe_err = nil
local first_pass = true

-- Restore from /var/run/5g-watchdog.state if it's recent enough.
-- Without this, a procd respawn mid-incident loses cooldown +
-- consecutive_failed_actions and the next cycle re-fires at zero
-- backoff against a wedged radio.
do
    local prev = read_state()
    local now = os.time()
    local prev_ts = prev and tonumber(prev.updated_ts) or 0
    if prev and prev_ts > 0 and (now - prev_ts) <= STATE_TTL then
        cooldown_until         = tonumber(prev.cooldown_until) or 0
        last_action_ts         = tonumber(prev.last_action_ts) or 0
        last_recovery_seconds  = tonumber(prev.last_recovery_seconds) or 0
        actions_total_mode_toggle      = tonumber(prev.actions_total_mode_toggle) or 0
        actions_total_bearer_reconnect = tonumber(prev.actions_total_bearer_reconnect) or 0
        consecutive_failed_actions     = tonumber(prev.consecutive_failed_actions) or 0
        nr_detached_since      = tonumber(prev.nr_detached_since) or 0
        alerted_failed         = (prev.alerted_failed == "1")
        alerted_detach_long    = (prev.alerted_detach_long == "1")
        log("restored state from %ds ago: cooldown_until=%d failed_actions=%d nr_detached_since=%d alerted_failed=%s alerted_detach_long=%s",
            now - prev_ts, cooldown_until, consecutive_failed_actions,
            nr_detached_since, tostring(alerted_failed), tostring(alerted_detach_long))
    elseif prev and prev_ts > 0 then
        log("ignoring stale state file (%ds old, ttl=%ds)", now - prev_ts, STATE_TTL)
    end
end

-- If we restart while NR is already detached we never see the
-- attached→detached transition, so nr_detached_since stays 0 and the
-- long-detach alert can never fire for this incident. Seed it now —
-- the worst case is we slightly underestimate detach duration if the
-- daemon was down longer than the restart gap, which is fine.
if first_p and not first_p.nr_attached then
    if nr_detached_since == 0 then
        nr_detached_since = os.time()
        log("startup: NR currently detached; seeding nr_detached_since=%d",
            nr_detached_since)
    else
        log("startup: NR currently detached; carrying nr_detached_since=%d (%ds ago)",
            nr_detached_since, os.time() - nr_detached_since)
    end
end

local function probe_summary(p)
    if not p then return "probe=nil" end
    return string.format(
        "state=%s nr_capable=%s nr_attached=%s nr_carriers=%d lte_carriers=%d mode_pref=%s",
        p.state, tostring(p.nr_capable),
        tostring(p.nr_attached), p.nr_carriers or 0, p.lte_carriers or 0,
        p.mode_pref or "")
end

while true do
    local p, err = probe()
    if not p then
        if last_probe_err ~= err then
            log("probe error: %s", err or "?")
            last_probe_err = err
        end
        emit_state(nil)
    else
        last_probe_err = nil
        if first_pass then
            log("initial probe: %s", probe_summary(p))
            first_pass = false
        else
            -- Compare to last probe and log notable transitions. None of
            -- these are actions on their own — they're the audit trail.
            if last_probe then
                if last_probe.state ~= p.state then
                    log("modem state: %s -> %s", last_probe.state, p.state)
                end
                if last_probe.nr_capable ~= p.nr_capable then
                    log("nr_capable: %s -> %s (mode_pref=%s)",
                        tostring(last_probe.nr_capable), tostring(p.nr_capable),
                        p.mode_pref or "")
                end
                if last_probe.nr_attached ~= p.nr_attached then
                    if p.nr_attached then
                        -- Natural recovery (not driven by our action)
                        -- is worth recording — tells us "the cell
                        -- brought NR back on its own, before we hit
                        -- the action threshold".
                        if last_action_ts == 0 or os.time() - last_action_ts > RECOVERY_MAX_WAIT then
                            log("NR re-attached on its own (cell-driven recovery): %s",
                                probe_summary(p))
                            on_recovery("cell-driven")
                        end
                    else
                        log("NR detached: %s", probe_summary(p))
                        nr_detached_since = os.time()
                    end
                end
            end
        end

        if not p.connected or not p.nr_capable then
            if consecutive_degraded > 0 then
                log("clearing degraded counter (%d) — connected=%s nr_capable=%s",
                    consecutive_degraded, tostring(p.connected), tostring(p.nr_capable))
            end
            consecutive_degraded = 0
        elseif p.nr_attached then
            if consecutive_failed_actions > 0 or alerted_failed or alerted_detach_long then
                on_recovery("steady-state probe")
            end
            consecutive_degraded = 0
        else
            -- Clamp so a long wedge doesn't grow consecutive_degraded
            -- to 400+ and spam the log with "sample 418/5".
            if consecutive_degraded < degraded_samples then
                consecutive_degraded = consecutive_degraded + 1
            end
            local now = os.time()
            local in_cooldown = now < cooldown_until
            -- Once clamped at the threshold, only log the per-sample
            -- line on the first hit; afterwards just log the deferral
            -- once per cooldown window.
            if consecutive_degraded < degraded_samples then
                log("degraded sample %d/%d (nr_carriers=%d)",
                    consecutive_degraded, degraded_samples, p.nr_carriers or 0)
            end
            if consecutive_degraded >= degraded_samples then
                if in_cooldown then
                    -- Single line per minute is fine — this is the
                    -- main "what's the watchdog doing right now"
                    -- breadcrumb when wedged.
                    log("threshold reached, cooldown active for another %ds (failures=%d)",
                        cooldown_until - now, consecutive_failed_actions)
                else
                    log("NR SCG dropped past hysteresis (%s) — taking action", probe_summary(p))
                    take_action()
                end
            end

            -- Long-detach alert: fires once per incident, independent
            -- of any cooldown. Catches the case where NR has been down
            -- for ages and we're stuck in backoff.
            if alert_detach_secs > 0
                    and not alerted_detach_long
                    and nr_detached_since > 0
                    and (now - nr_detached_since) >= alert_detach_secs then
                notify_telegram(string.format(
                    "🔻 %s 5G NR detached for %dm (LTE-only)",
                    HOSTNAME, math.floor((now - nr_detached_since) / 60)))
                alerted_detach_long = true
            end
        end

        emit_state(p)
        last_probe = p
    end
    utils.sleep(poll_interval)
end
