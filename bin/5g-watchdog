#!/usr/bin/env lua
-- 5g-watchdog: detect NSA 5G NR SCG drops on the RM520N and force a
-- re-attach via ModemManager.
--
-- Failure mode targeted: the modem stays attached to the LTE master
-- but the cell does not (re)add the NR secondary carrier, so the
-- bearer keeps working at LTE-only throughput. Recovery requires the
-- UE to re-advertise NSA capability on a fresh attach.
--
-- Two-stage recovery:
--   1. mmcli --disable + --enable (NAS detach/attach, ~8s dropout).
--   2. mmcli --set-allowed-modes='4g' then restore (RAT toggle,
--      forces firmware to drop+restart NR measurements).
-- Stage 2 only runs if stage 1 did not recover NR after the cooldown.
-- After two failed stages in a row the watchdog stops trying and
-- flags `capped=1` for Prometheus to alert on.
--
-- All modem reads go through `mmcli -J` (machine-readable JSON). No AT
-- serial contention, nothing fights MM for ownership of the modem.

package.path = "/usr/lib/lua/?.lua;/usr/lib/lua/?/init.lua;" .. package.path

local quectel_uci = require("quectel.uci")
local utils = require("quectel.utils")
local jsonc = require("luci.jsonc")

local STATE_PATH = "/var/run/5g-watchdog.state"
local RECOVERY_POLL_INTERVAL = 3   -- seconds between mmcli polls while waiting for NR
local RECOVERY_MAX_WAIT = 60       -- give NR up to 60s to re-attach after action

-- Log via `logger -t 5g-watchdog` so messages land in syslog (logread)
-- regardless of whether we're under procd or running standalone. We
-- deliberately don't also write to stderr: procd's ulog wiring would
-- duplicate every line in logread when the service is running normally,
-- which is the common case. The fork-per-log-line cost is fine — we
-- log on transitions only, so cadence is sub-1/min in steady state.
local function log(fmt, ...)
    local msg = string.format(fmt, ...)
    local p = io.popen("logger -t 5g-watchdog", "w")
    if p then
        p:write(msg)
        p:close()
    end
end

-- Wire SIGTERM/SIGINT/SIGHUP to a clean exit so procd-driven stops show
-- up in syslog as a deliberate shutdown rather than a silent vanish.
-- luaposix is a hard dep of this package so the pcall fallback is just
-- belt-and-braces for stripped-down test envs.
local posix_signal_ok, posix_signal = pcall(require, "posix.signal")
if posix_signal_ok then
    local function shutdown(signum)
        log("received signal %d, shutting down", signum)
        os.exit(0)
    end
    posix_signal.signal(posix_signal.SIGTERM, shutdown)
    posix_signal.signal(posix_signal.SIGINT, shutdown)
    posix_signal.signal(posix_signal.SIGHUP, shutdown)
end

-- ---------------------------------------------------------------------
-- mmcli helpers
-- ---------------------------------------------------------------------

-- Run a command, return (stdout, exit_status). Uses io.popen so we
-- never block on a mmcli that wedges itself; the parent procd respawn
-- catches the case where we stall longer than RECOVERY_MAX_WAIT.
local function run(cmd)
    local p = io.popen(cmd .. " 2>&1", "r")
    if not p then return nil, -1 end
    local out = p:read("*a") or ""
    local ok, _, code = p:close()
    return out, ok and 0 or (code or 1)
end

-- Run a command, parse stdout as JSON. Returns (table, 0) on success,
-- (nil, code) otherwise. Used for `mmcli -J ...` calls.
local function run_json(cmd)
    local out, code = run(cmd)
    if code ~= 0 or not out or out == "" then return nil, code end
    local parsed = jsonc.parse(out)
    if type(parsed) ~= "table" then return nil, -1 end
    return parsed, 0
end

local function discover_modem_index()
    local data = run_json("mmcli -J -L")
    local list = data and data["modem-list"]
    if type(list) ~= "table" or not list[1] then return nil end
    local idx = list[1]:match("/Modem/(%d+)$")
    return idx and tonumber(idx) or nil
end

-- ---------------------------------------------------------------------
-- state file (atomic write)
-- ---------------------------------------------------------------------

local function write_state(state)
    local tmp = STATE_PATH .. ".tmp"
    local f = io.open(tmp, "w")
    if not f then return end
    -- Sorted keys for diff-friendly output; volume is small.
    local keys = {}
    for k in pairs(state) do table.insert(keys, k) end
    table.sort(keys)
    for _, k in ipairs(keys) do
        f:write(string.format("%s=%s\n", k, tostring(state[k])))
    end
    f:close()
    os.rename(tmp, STATE_PATH)
end

-- ---------------------------------------------------------------------
-- action stages
-- ---------------------------------------------------------------------

local function stage1_disable_enable(idx)
    log("stage1: mmcli --disable + --enable")
    local _, c1 = run(string.format("mmcli -m %d --disable", idx))
    utils.sleep(2)
    local _, c2 = run(string.format("mmcli -m %d --enable", idx))
    if c1 ~= 0 or c2 ~= 0 then
        log("stage1: disable=%d enable=%d (non-zero)", c1, c2)
    end
end

-- Stage 2: record the current allowed-modes+preferred-mode, drop to
-- 4g-only, then restore exactly. We restore in a pcall-style ordering
-- so even if the second mmcli call fails, the daemon will retry the
-- restore on the next poll (state file flags "capped" so the user can
-- see something is wrong from Prometheus).
local function stage2_mode_toggle(idx, allowed_csv, preferred)
    -- mmcli expects pipe-separated mode lists; we keep CSV in state file
    -- for human/Prometheus readability, so convert at the call site.
    local allowed_pipes = (allowed_csv or ""):gsub(",", "|")
    if allowed_pipes == "" then
        log("stage2: refusing to run, no current allowed modes captured")
        return false
    end
    local restore = string.format(
        "mmcli -m %d --set-allowed-modes='%s'%s",
        idx, allowed_pipes,
        (preferred and preferred ~= "" and preferred ~= "none")
            and (" --set-preferred-mode=" .. preferred) or "")
    log("stage2: drop to 4g, then restore: %s", restore)

    local _, c1 = run(string.format("mmcli -m %d --set-allowed-modes='4g'", idx))
    utils.sleep(4)
    local _, c2 = run(restore)
    if c1 ~= 0 or c2 ~= 0 then
        log("stage2: drop=%d restore=%d (non-zero) — restore cmd: %s",
            c1, c2, restore)
        return false
    end
    return true
end

-- ---------------------------------------------------------------------
-- detection
-- ---------------------------------------------------------------------

-- mmcli serialises `current-modes` as a single human-readable string
-- of the form "allowed: 3g, 4g, 5g; preferred: 5g" — the `-J` flag
-- does NOT split it into structured fields, so this stays a string
-- parse. Returns (allowed_list, preferred_string).
local function parse_current_modes(s)
    if not s or s == "" or s == "--" then return {}, "" end
    local allowed_part, preferred = s:match("^%s*allowed:%s*(.-)%s*;%s*preferred:%s*(.-)%s*$")
    if not allowed_part then
        -- some mmcli versions omit the preferred half on single-mode setups
        allowed_part = s:match("^%s*allowed:%s*(.-)%s*$") or s
        preferred = ""
    end
    local list = {}
    for m in allowed_part:gmatch("[^,%s]+") do table.insert(list, m) end
    return list, preferred or ""
end

local function probe(idx)
    local data, code = run_json(string.format("mmcli -m %d -J", idx))
    if not data or type(data.modem) ~= "table" then
        return nil, "mmcli -J failed (code=" .. tostring(code) .. ")"
    end
    local g = data.modem.generic or {}
    local state = g.state or "unknown"
    local techs = {}
    if type(g["access-technologies"]) == "table" then
        for _, t in ipairs(g["access-technologies"]) do
            if t ~= "--" then table.insert(techs, t) end
        end
    end
    local allowed, preferred = parse_current_modes(g["current-modes"])

    local has_nr = false
    for _, t in ipairs(techs) do if t == "5gnr" then has_nr = true break end end

    local nr_capable = false
    for _, m in ipairs(allowed) do if m == "5g" then nr_capable = true break end end

    return {
        state = state,
        nr_attached = has_nr,
        nr_capable = nr_capable,
        connected = (state == "connected"),
        allowed_csv = table.concat(allowed, ","),
        preferred = preferred,
        techs_csv = table.concat(techs, ","),
    }
end

-- ---------------------------------------------------------------------
-- main loop
-- ---------------------------------------------------------------------

local enabled = quectel_uci.get_bool("quectel", "watchdog", "enabled", true)
if not enabled then
    log("watchdog disabled in UCI; exiting")
    os.exit(0)
end

local poll_interval     = quectel_uci.get_number("quectel", "watchdog", "poll_interval", 60)
local degraded_samples  = quectel_uci.get_number("quectel", "watchdog", "degraded_samples", 5)
local cooldown_seconds  = quectel_uci.get_number("quectel", "watchdog", "cooldown", 900)
local daily_cap         = quectel_uci.get_number("quectel", "watchdog", "daily_cap", 6)
local stage2_enabled    = quectel_uci.get_bool("quectel", "watchdog", "enable_mode_toggle", true)

log("starting up: looking for modem via ModemManager")

local idx = discover_modem_index()
if not idx then
    log("no modem visible to ModemManager; sleeping 30s and retrying")
    utils.sleep(30)
    idx = discover_modem_index()
    if not idx then
        log("still no modem; exiting (procd will respawn)")
        os.exit(1)
    end
end
log("started: modem=%d poll=%ds hysteresis=%d cooldown=%ds daily_cap=%d stage2=%s",
    idx, poll_interval, degraded_samples, cooldown_seconds, daily_cap,
    stage2_enabled and "on" or "off")

local consecutive_degraded = 0
local cooldown_until = 0
local last_action_ts = 0
local last_action_stage = ""
local last_recovery_seconds = 0
local actions_total = { disable_enable = 0, mode_toggle = 0 }
local action_history = {}            -- list of {ts, stage}
local consecutive_failed_actions = 0 -- resets on healthy NR
local capped = false

local function actions_in_24h()
    local now = os.time()
    local cutoff = now - 86400
    local kept = {}
    for _, e in ipairs(action_history) do
        if e.ts >= cutoff then table.insert(kept, e) end
    end
    action_history = kept
    return #kept
end

local function emit_state(p)
    local s = {
        nr_attached            = (p and p.nr_attached) and 1 or 0,
        nr_capable             = (p and p.nr_capable) and 1 or 0,
        connected              = (p and p.connected) and 1 or 0,
        modem_state            = p and p.state or "unknown",
        techs                  = p and p.techs_csv or "",
        allowed_modes          = p and p.allowed_csv or "",
        preferred_mode         = p and p.preferred or "",
        consecutive_degraded   = consecutive_degraded,
        cooldown_until         = cooldown_until,
        last_action_ts         = last_action_ts,
        last_action_stage      = last_action_stage,
        last_recovery_seconds  = last_recovery_seconds,
        actions_24h            = actions_in_24h(),
        actions_total_disable_enable = actions_total.disable_enable,
        actions_total_mode_toggle    = actions_total.mode_toggle,
        consecutive_failed_actions   = consecutive_failed_actions,
        capped                 = capped and 1 or 0,
        updated_ts             = os.time(),
        modem_index            = idx,
    }
    write_state(s)
end

-- After an action, poll every RECOVERY_POLL_INTERVAL up to RECOVERY_MAX_WAIT
-- to record how long it took NR to come back. Returns seconds to recovery
-- (or RECOVERY_MAX_WAIT+1 if it never came back within the window).
local function measure_recovery()
    local t0 = os.time()
    while os.time() - t0 < RECOVERY_MAX_WAIT do
        utils.sleep(RECOVERY_POLL_INTERVAL)
        local p = probe(idx)
        if p and p.nr_attached then
            return os.time() - t0, p
        end
    end
    return RECOVERY_MAX_WAIT + 1, probe(idx)
end

local function take_action()
    local now = os.time()
    if now < cooldown_until then return end
    if actions_in_24h() >= daily_cap then
        if not capped then
            log("daily cap (%d) reached, backing off until tomorrow", daily_cap)
        end
        capped = true
        return
    end
    capped = false

    -- Snapshot modes for stage 2 restore (in case we need it).
    local pre = probe(idx)
    if not pre then
        log("probe failed before action; skipping this round")
        return
    end

    local stage
    if consecutive_failed_actions == 0 or not stage2_enabled then
        stage = "disable_enable"
        stage1_disable_enable(idx)
    else
        stage = "mode_toggle"
        local ok = stage2_mode_toggle(idx, pre.allowed_csv, pre.preferred)
        if not ok then
            log("stage2 reported a non-zero exit; will retry restore on next pass")
        end
    end

    local recovered_in, post = measure_recovery()
    last_action_ts = os.time()
    last_action_stage = stage
    last_recovery_seconds = recovered_in
    actions_total[stage] = actions_total[stage] + 1
    table.insert(action_history, { ts = last_action_ts, stage = stage })
    cooldown_until = last_action_ts + cooldown_seconds

    if post and post.nr_attached then
        log("recovered NR via %s in %ds", stage, recovered_in)
        consecutive_failed_actions = 0
    else
        consecutive_failed_actions = consecutive_failed_actions + 1
        log("action %s did NOT recover NR within %ds (consecutive failures=%d)",
            stage, RECOVERY_MAX_WAIT, consecutive_failed_actions)
        if consecutive_failed_actions >= 2 then
            capped = true
            log("two consecutive failed actions — flagging capped, no further action this 24h window")
        end
    end
    consecutive_degraded = 0
end

-- Transition-aware logging: keep the previous probe so we log only when
-- something actually changed (modem state flipped, NR came/went, user
-- pinned LTE, capped flag toggled, etc.) instead of spamming a line per
-- 60s tick. Counters during a degradation run are still logged each
-- sample so progress toward the action threshold is visible in syslog.
local last_probe = nil
local last_capped = false
local last_probe_err = nil
local first_pass = true

local function probe_summary(p)
    if not p then return "probe=nil" end
    return string.format("state=%s connected=%s nr_capable=%s nr_attached=%s techs=[%s] modes=[%s] preferred=%s",
        p.state, tostring(p.connected), tostring(p.nr_capable),
        tostring(p.nr_attached), p.techs_csv, p.allowed_csv, p.preferred)
end

while true do
    local p, err = probe(idx)
    if not p then
        -- Modem may have moved to a different ModemManager index (USB
        -- reset, modem firmware reboot, udev re-enumeration). Without
        -- rediscovery we'd probe a dead index forever even after the
        -- kernel sees the modem come back. Try `mmcli -L` again; if it
        -- gives us a different index, switch and retry the probe in
        -- this same tick rather than waiting a full poll interval.
        local new_idx = discover_modem_index()
        if new_idx and new_idx ~= idx then
            log("modem index changed: %d -> %d (was probing a dead index)", idx, new_idx)
            idx = new_idx
            last_probe = nil  -- old transitions don't apply to a new modem
            p, err = probe(idx)
        end
    end
    if not p then
        if last_probe_err ~= err then
            log("probe error: %s", err or "?")
            last_probe_err = err
        end
        emit_state(nil)
    else
        last_probe_err = nil
        if first_pass then
            log("initial probe: %s", probe_summary(p))
            first_pass = false
        else
            -- Compare to last probe and log notable transitions. None of
            -- these are actions on their own — they're the audit trail.
            if last_probe then
                if last_probe.state ~= p.state then
                    log("modem state: %s -> %s", last_probe.state, p.state)
                end
                if last_probe.nr_capable ~= p.nr_capable then
                    log("nr_capable: %s -> %s (allowed modes: [%s] preferred=%s)",
                        tostring(last_probe.nr_capable), tostring(p.nr_capable),
                        p.allowed_csv, p.preferred)
                end
                if last_probe.nr_attached ~= p.nr_attached then
                    if p.nr_attached then
                        -- Natural recovery (not driven by our action) is worth
                        -- recording — tells us "the cell brought NR back on its
                        -- own, before we hit the action threshold".
                        if last_action_ts == 0 or os.time() - last_action_ts > RECOVERY_MAX_WAIT then
                            log("NR re-attached on its own (cell-driven recovery): %s",
                                probe_summary(p))
                        end
                    else
                        log("NR detached: %s", probe_summary(p))
                    end
                end
            end
        end

        if not p.connected or not p.nr_capable then
            if consecutive_degraded > 0 then
                log("clearing degraded counter (%d) — connected=%s nr_capable=%s",
                    consecutive_degraded, tostring(p.connected), tostring(p.nr_capable))
            end
            consecutive_degraded = 0
        elseif p.nr_attached then
            consecutive_degraded = 0
            consecutive_failed_actions = 0
        else
            consecutive_degraded = consecutive_degraded + 1
            local now = os.time()
            local in_cooldown = now < cooldown_until
            log("degraded sample %d/%d (techs=[%s])%s",
                consecutive_degraded, degraded_samples, p.techs_csv,
                in_cooldown and string.format(" — cooldown active for another %ds", cooldown_until - now) or "")
            if consecutive_degraded == degraded_samples then
                if in_cooldown then
                    log("threshold reached but cooldown active until %d (in %ds); deferring",
                        cooldown_until, cooldown_until - now)
                elseif actions_in_24h() >= daily_cap then
                    log("threshold reached but daily cap (%d) hit; will not act in this 24h window",
                        daily_cap)
                else
                    log("NR SCG dropped past hysteresis (%s) — taking action", probe_summary(p))
                    take_action()
                end
            end
        end

        if capped ~= last_capped then
            if capped then
                log("entering capped state (no further action this 24h window)")
            else
                log("clearing capped state — resuming normal operation")
            end
            last_capped = capped
        end

        emit_state(p)
        last_probe = p
    end
    utils.sleep(poll_interval)
end
